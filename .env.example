# Banco de Dados (Docker usa "db" como host)
DATABASE_URL="mysql://si_user:si_pass@db:3306/si_leads"

# MySQL (usado pelo docker-compose)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=si_leads
MYSQL_USER=si_user
MYSQL_PASSWORD=si_pass

# JWT
JWT_SECRET="mude_esta_chave_em_producao_use_algo_longo_e_aleatorio"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
FRONTEND_URL="http://localhost:3000"

# Microsserviço de IA (Docker usa "ai" como host)
AI_SERVICE_URL="http://ai:8000"

# Groq API (https://console.groq.com)
GROQ_API_KEY=sua_groq_api_key_aqui